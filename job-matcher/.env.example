# OpenAI API Key (for embeddings and JD parsing)
OPENAI_API_KEY=sk-...

# SMTP settings for daily digest email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Where to send the daily digest
DIGEST_EMAIL_TO=your-email@gmail.com

# Time to send daily digest (24h format, local time)
DIGEST_TIME=07:00
